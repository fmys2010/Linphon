#!/usr/bin/env bash
set -euo pipefail

CONFIG_PATH=
DATA_ROOT=
NOTICES_PATH=

usage() {
  cat <<'EOF'
Usage:
  fake-psiphon-tunnel-core-x86_64 -config PATH -dataRootDirectory PATH -notices PATH
EOF
}

read_json_number() {
  local config_path=$1
  local key=$2

  awk -F: -v key="\"$key\"" '
    index($0, key) {
      value = $2
      gsub(/[^0-9]/, "", value)
      print value
      exit
    }
  ' "$config_path"
}

read_json_string() {
  local config_path=$1
  local key=$2

  awk -F: -v key="\"$key\"" '
    index($0, key) {
      value = substr($0, index($0, ":") + 1)
      gsub(/^[[:space:]]*"/, "", value)
      gsub(/",?[[:space:]]*$/, "", value)
      print value
      exit
    }
  ' "$config_path"
}

append_notice() {
  local notice_type=$1
  local payload=$2
  printf '{"noticeType":"%s","data":%s}\n' "$notice_type" "$payload" >> "$NOTICES_PATH"
}

shutdown() {
  append_notice "Exiting" '{"reason":"signal"}'
  exit 0
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    -config)
      CONFIG_PATH=$2
      shift 2
      ;;
    -dataRootDirectory)
      DATA_ROOT=$2
      shift 2
      ;;
    -notices)
      NOTICES_PATH=$2
      shift 2
      ;;
    --help|-h)
      usage
      exit 0
      ;;
    *)
      printf '[fake-psiphon] ignoring extra argument: %s\n' "$1" >&2
      shift
      ;;
  esac
done

if [ -z "$CONFIG_PATH" ] || [ -z "$DATA_ROOT" ] || [ -z "$NOTICES_PATH" ]; then
  usage >&2
  exit 64
fi

mkdir -p "$DATA_ROOT" "$(dirname -- "$NOTICES_PATH")"

HTTP_PORT=$(read_json_number "$CONFIG_PATH" LocalHttpProxyPort)
SOCKS_PORT=$(read_json_number "$CONFIG_PATH" LocalSocksProxyPort)
REMOTE_FILENAME=$(read_json_string "$CONFIG_PATH" RemoteServerListDownloadFilename)
EGRESS_REGION=$(read_json_string "$CONFIG_PATH" EgressRegion)

printf 'fake remote list for %s\n' "$REMOTE_FILENAME" > "$DATA_ROOT/$REMOTE_FILENAME"
printf 'config=%s\n' "$CONFIG_PATH" > "$DATA_ROOT/runtime.info"
printf 'data_root=%s\n' "$DATA_ROOT" >> "$DATA_ROOT/runtime.info"
printf 'notices=%s\n' "$NOTICES_PATH" >> "$DATA_ROOT/runtime.info"
printf 'egress_region=%s\n' "$EGRESS_REGION" >> "$DATA_ROOT/runtime.info"

append_notice "ListeningHttpProxyPort" "{\"port\":$HTTP_PORT}"
append_notice "ListeningSocksProxyPort" "{\"port\":$SOCKS_PORT}"
append_notice "Tunnels" '{"count":1,"state":"connected-for-test"}'

trap shutdown INT TERM

while :; do
  sleep 1
done
